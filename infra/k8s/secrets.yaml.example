apiVersion: v1
kind: Secret
metadata:
  name: risk-platform-secrets
  namespace: risk-platform
type: Opaque
stringData:
  database-url: "postgresql://user:password@rds-endpoint:5432/risk_platform"
  redis-url: "redis://redis-cluster:6379"
  jwt-secret: "CHANGE-ME-GENERATE-STRONG-SECRET"
  redis-password: "CHANGE-ME-REDIS-PASSWORD"
  # Add other secrets as needed

---
# Instructions:
# 1. Copy this file to secrets.yaml
# 2. Fill in all values
# 3. DO NOT commit secrets.yaml to Git
# 4. Apply using: kubectl apply -f infra/k8s/secrets.yaml

