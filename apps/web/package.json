{
  "name": "pfrp-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "three": "^0.182.0",
    "zustand": "^4.5.2"
  },
  "scripts": {
    "dev": "vite",
    "dev:fresh": "rm -rf node_modules/.vite && vite",
    "build": "vite build && node scripts/check-chunk-size.mjs",
    "preview": "vite preview",
    "preview:prod": "serve -s dist -l 5180",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prebuild": "mkdir -p public/cesium && (cp -R node_modules/cesium/Build/Cesium/Workers public/cesium/ && cp -R node_modules/cesium/Build/Cesium/Assets public/cesium/ && cp -R node_modules/cesium/Build/Cesium/ThirdParty public/cesium/) || true"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^8.9.35",
    "@deck.gl/core": "^8.9.35",
    "@deck.gl/layers": "^8.9.35",
    "@deck.gl/react": "^8.9.35",
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.2.0",
    "@react-three/drei": "^9.96.1",
    "@react-three/fiber": "^8.15.16",
    "@tanstack/react-query": "^5.18.0",
    "@tanstack/react-virtual": "^3.1.3",
    "axios": "^1.6.5",
    "cesium": "^1.124.0",
    "clsx": "^2.1.0",
    "d3": "^7.8.5",
    "deck.gl": "^8.9.35",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "maplibre-gl": "^4.0.0",
    "plotly.js": "^2.27.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.29.0",
    "react-force-graph-3d": "^1.29.0",
    "react-map-gl": "^7.1.7",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.21.3",
    "recharts": "^2.10.4",
    "three": "^0.182.0",
    "web-ifc": "0.0.57",
    "@xeokit/xeokit-bim-viewer": "^2.7.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^24.0.0",
    "vitest": "^1.3.1",
    "@types/d3": "^7.4.3",
    "@types/plotly.js": "^2.12.29",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "@playwright/test": "^1.49.0",
    "wait-on": "^7.2.0"
  }
}
