# Copy to .env and adjust. Do not commit .env.
# Full deploy checklist (all DBs and keys): ../../docs/DEPLOY_FULL.md

# ---------- Docker Compose (optional) ----------
# For production, set these and use: docker compose --env-file .env up -d
# POSTGRES_USER=pfrp_user
# POSTGRES_PASSWORD=strong_password_here
# NEO4J_PASSWORD=strong_neo4j_password
# MINIO_ACCESS_KEY=minio_user
# MINIO_SECRET_KEY=strong_minio_password

# Database (use SQLite for simple/local deploy)
USE_SQLITE=true
DATABASE_URL=sqlite:///./prod.db

# Security (production: use openssl rand -hex 32)
# SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Environment
ENVIRONMENT=production
DEBUG=false

# Demo servers: allow "Load demo data" button (POST /api/v1/seed/seed) without admin auth
# ALLOW_SEED_IN_PRODUCTION=true

# Omniverse / E2CC — URL приложения Earth-2 Command Center (кнопка "Open in Omniverse")
E2CC_BASE_URL=http://localhost:8010

# NVIDIA NIM (FourCastNet, CorrDiff) — включить, если запущены контейнеры с GPU
USE_LOCAL_NIM=false
# NGC_API_KEY=your_ngc_key

# ========== GTC: NVIDIA Riva, Dynamo, Triton ==========
# See docs/GTC_NVIDIA_SETUP.md for full setup.

# NVIDIA Riva (Speech AI) — voice alerts, TTS for reports. Install: pip install .[nvidia]
# ENABLE_RIVA=true
# RIVA_URL=http://localhost:50051

# NVIDIA Dynamo — low-latency inference (deploy per https://docs.nvidia.com/dynamo/)
# ENABLE_DYNAMO=false
# DYNAMO_URL=http://localhost:8004

# Triton Inference Server — self-hosted LLM (docker compose -f docker-compose.nvidia.yml --profile gtc up -d triton)
# ENABLE_TRITON=false
# TRITON_URL=http://localhost:8000
# TRITON_LLM_MODEL=nemotron
# USE_TENSORRT_LLM=false

# Optional: cuOpt (routing), IndeX (volumetric viz), WaveWorks (ocean)
# ENABLE_CUOPT=false
# CUOPT_URL=http://localhost:8005
# ENABLE_INDEX_VIZ=false
# INDEX_URL=http://localhost:8006
# ENABLE_WAVEWORKS=false
# WAVEWORKS_URL=http://localhost:8007

# Redis — по умолчанию выключен (config.py). Для продакшена или docker compose up -d redis:
# ENABLE_REDIS=true
# REDIS_URL=redis://localhost:6379

# TimescaleDB — хранилище временных рядов риска (timeline, risk-at-time). Схема: scripts/init_timescale.sql
# ENABLE_TIMESCALE=true
# TIMESCALE_URL=postgresql+asyncpg://pfrp_user:pfrp_secret_2024@localhost:5433/timeseries

# Neo4j (Knowledge Graph). Set true only if Neo4j is running (e.g. docker compose up -d neo4j).
# For API-only / SQLite / no-Docker: set false to avoid "Circuit breaker neo4j OPEN" and connection errors.
ENABLE_NEO4J=false

# CORS (добавьте домен фронта)
# CORS_ORIGINS=["https://risk.saa-alliance.com","http://localhost:5180"]

# ========== Active Incidents (live fires, earthquakes, weather alerts) ==========
# NASA FIRMS: free MAP_KEY from https://firms.modaps.eosdis.nasa.gov/api/area/
# FIRMS_MAP_KEY=your_firms_map_key
# NWS Alerts API requires no key (api.weather.gov)

# ========== SCSS Phase 5: ERP/PLM sync ==========
# Когда заданы — адаптеры синхронизации используют реальные эндпоинты вместо stub.
# SCSS_SAP_BASE_URL=https://sap.example.com/api
# SCSS_SAP_TOKEN=
# SCSS_ORACLE_BASE_URL=https://oracle-erp.example.com/api
# SCSS_ORACLE_TOKEN=
# SCSS_EDI_ENDPOINT_URL=https://edi-gateway.example.com/suppliers
# SCSS_EDI_API_KEY=

# ========== SCSS Phase 6: Sanctions screening (OFAC/EU) ==========
# For production sanctions screening set SCSS_OFAC_API_URL and optionally SCSS_EU_SANCTIONS_URL.
# If not set, the platform uses a built-in demo list (not for production use).
# SCSS_OFAC_API_URL=https://api.treasury.gov/ofac/sdn
# SCSS_OFAC_API_KEY=
# SCSS_EU_SANCTIONS_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xml-full-sanctions-list
# SCSS_EU_SANCTIONS_API_KEY=

# ========== System Overseer (critical routes probe) ==========
# If set, Overseer will GET /api/v1/health, /climate/indicators, /climate/forecast and alert on 404/5xx
# OVERSEER_CRITICAL_ROUTES_BASE_URL=http://127.0.0.1:9002

# ========== Cesium Ion (self-hosted or cloud) ==========
# Frontend reads GET /api/v1/config/cesium. For self-hosted/offline/classified, point to your Ion server.
# CESIUM_ION_URL=https://ion.cesium.com
# CESIUM_ION_TOKEN=           # Cesium Ion default access token (or self-hosted token)
# CESIUM_TERRAIN_ASSET_ID=1   # World Terrain
# CESIUM_BATHYMETRY_ASSET_ID=0   # 0=skip (avoids 404); set 2426648 only if your Ion account has World Bathymetry
# CESIUM_BUILDINGS_ASSET_ID=96188
# CESIUM_GOOGLE_PHOTOREALISTIC_ASSET_ID=2275207

# ========== Risk Intelligence Engine (v2) ==========
# risk_model_version=2 enables GDELT, World Bank, IMF, OFAC, Open-Meteo + hysteresis zones.
# RISK_MODEL_VERSION=1
# FRED_API_KEY=           # optional; FRED for US economic indicators
# GDELT_CACHE_TTL_MINUTES=15

# ========== ARIN Platform (Unified Analysis export) ==========
# When set, risk data is automatically sent to ARIN after calculations (Analytics, SRO, Stress Tests)
# ARIN_BASE_URL=https://arin.saa-alliance.com            # base URL — used for verdict proxy + fallback export
# ARIN_EXPORT_URL=https://arin.saa-alliance.com/api/v1/unified/export
# ARIN_API_KEY=           # leave empty unless ARIN admin provides a key
# ARIN_DEFAULT_ENTITY_ID=portfolio_global  # must match entity registered in ARIN

# ========== Google Earth Engine (climate, flood, elevation, land use) ==========
# See docs/EARTH_ENGINE_SETUP.md. Without these, /earth-engine/* returns mock data.
# ENABLE_EARTH_ENGINE=true
# GCLOUD_PROJECT_ID=your-gcp-project-id
# Path to service account JSON key file, or inline JSON string (must contain client_email):
# GCLOUD_SERVICE_ACCOUNT_JSON=/path/to/ee-service-account-key.json
