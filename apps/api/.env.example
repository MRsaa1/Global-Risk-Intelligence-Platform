# Copy to .env and adjust. Do not commit .env.

# Database (use SQLite for simple/local deploy)
USE_SQLITE=true
DATABASE_URL=sqlite:///./prod.db

# Environment
ENVIRONMENT=production
DEBUG=false

# Omniverse / E2CC — URL приложения Earth-2 Command Center (кнопка "Open in Omniverse")
E2CC_BASE_URL=http://localhost:8010

# NVIDIA NIM (FourCastNet, CorrDiff) — включить, если запущены контейнеры с GPU
USE_LOCAL_NIM=false
# NGC_API_KEY=your_ngc_key

# ========== GTC: NVIDIA Riva, Dynamo, Triton ==========
# See docs/GTC_NVIDIA_SETUP.md for full setup.

# NVIDIA Riva (Speech AI) — voice alerts, TTS for reports. Install: pip install .[nvidia]
# ENABLE_RIVA=true
# RIVA_URL=http://localhost:50051

# NVIDIA Dynamo — low-latency inference (deploy per https://docs.nvidia.com/dynamo/)
# ENABLE_DYNAMO=false
# DYNAMO_URL=http://localhost:8004

# Triton Inference Server — self-hosted LLM (docker compose -f docker-compose.nvidia.yml --profile gtc up -d triton)
# ENABLE_TRITON=false
# TRITON_URL=http://localhost:8000
# TRITON_LLM_MODEL=nemotron
# USE_TENSORRT_LLM=false

# Optional: cuOpt (routing), IndeX (volumetric viz), WaveWorks (ocean)
# ENABLE_CUOPT=false
# CUOPT_URL=http://localhost:8005
# ENABLE_INDEX_VIZ=false
# INDEX_URL=http://localhost:8006
# ENABLE_WAVEWORKS=false
# WAVEWORKS_URL=http://localhost:8007

# CORS (добавьте домен фронта)
# CORS_ORIGINS=["https://risk.saa-alliance.com","http://localhost:5180"]
