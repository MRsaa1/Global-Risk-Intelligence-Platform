# Brev deployment — copy to .env when deploying on Brev
# ./scripts/brev-deploy.sh creates .env automatically; this file is for reference.

USE_SQLITE=true
USE_DATA_FEDERATION_PIPELINES=true
USE_LOCAL_NIM=true
FOURCASTNET_NIM_URL=http://localhost:8001

# NVIDIA API Key — тот же ключ, что и локально (NGC API Key), для LLM и отчётов
# Без него: executive summary будет из шаблона; с ключом — генерация через NVIDIA.
NVIDIA_API_KEY=

# DFM: при запущенном GPU/NIM — включить пайплайны (geodata_risk, climate_stress, weather_forecast)
# USE_DATA_FEDERATION_PIPELINES=true

# Omniverse / E2CC: URL Earth-2 Command Center для кнопки «Open in Omniverse»
# На saaaliance: после запуска E2CC (./deploy/deploy_e2cc.sh -s) раскомментировать и задать URL.
E2CC_BASE_URL=http://localhost:8010
